# AttendX Environment Variables
# Copy this to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Face Engine
FACE_DETECTION_THRESHOLD=0.5
FACE_RECOGNITION_THRESHOLD=0.4
DEVICE=cpu

# Camera (example RTSP URLs)
CAMERA_1_RTSP=rtsp://admin:password@192.168.1.100:554/stream
CAMERA_2_RTSP=rtsp://admin:password@192.168.1.101:554/stream
